# =========================================================

# NutriPrompt · Professional .gitignore

# =========================================================

# =========================================================

# Python

# =========================================================

**pycache**/
*.py[cod]
*$py.class
*.so
*.pyd
*.pyo

# =========================================================

# Virtual Environments

# =========================================================

venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

# =========================================================

# Django

# =========================================================

db.sqlite3
*.sqlite3

staticfiles/

# =========================================================

# Environment Variables / Secrets

# =========================================================

.env
*.env
.env.local
.env.production

# =========================================================

# Logs

# =========================================================

*.log
logs/

# =========================================================

# macOS / Windows

# =========================================================

.DS_Store
Thumbs.db
desktop.ini

# =========================================================

# IDEs / Editors

# =========================================================

.vscode/
.idea/

*.swp
*.swo

# =========================================================

# Temporary / Backup Files

# =========================================================

*.tmp
*.bak
*.temp

# =========================================================

# Python Packaging

# =========================================================

build/
dist/
.eggs/
*.egg-info/
pip-wheel-metadata/

# =========================================================

# Testing / Coverage

# =========================================================

.pytest_cache/
.coverage
htmlcov/
.cache/

# =========================================================

# Jupyter

# =========================================================

.ipynb_checkpoints/

# =========================================================

# AI / Machine Learning

# =========================================================

# HuggingFace

.cache/huggingface/
huggingface_cache/

# LLM cache

starlit_cache/

# Model weights

*.ckpt
*.pt
*.pth

# =========================================================

# Data Files

# =========================================================

# Raw datasets

data/raw/
data/interim/

# Processed datasets

# (Keep ignored if generated automatically)

data/processed/

# =========================================================

# Media Uploads (Generated Content)

# =========================================================

# Generated nutrition plans

media/resultados/

# OCR uploads

media/vision/

# Uploaded forms

media/formularios/

# =========================================================

# Generated Documents

# =========================================================

# Generated PDFs

*.pdf

# Generated HTML exports only

media/resultados/*.html

# Keep documentation examples

!docs/**/*.pdf
!docs/**/*.html

# =========================================================

# Experimental / Local Files

# =========================================================

prompt_generado.txt
debug_output.txt
scratch.py

# =========================================================

# Frontend (Future)

# =========================================================

node_modules/

# =========================================================

# Archives

# =========================================================

*.zip
*.tar
*.gz

# =========================================================

# WeasyPrint

# =========================================================

weasyprint_cache/

# =========================================================

# AI Generated Outputs

# =========================================================

ai_outputs/
ocr_outputs/
vision_outputs/

# =========================================================

# Keep Project Structure

# =========================================================

!media/.gitkeep
!data/.gitkeep
!docs/data/.gitkeep
